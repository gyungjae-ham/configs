[
  {
    "label": "django",
    "command": "direnv exec . uv run python manage.py runserver",
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always"
  },
  {
    "label": "spring-local",
    "command": "./gradlew bootRun --console=plain --args='--spring.profiles.active=local'",
    "env": {
      "AWS_PROFILE": "athler-dev"
    },
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always"
  },
  {
    "label": "spring-test",
    "command": "./gradlew bootRun --console=plain --args='--spring.profiles.active=dev'",
    "env": {
      "AWS_PROFILE": "athler-dev"
    },
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always"
  },
  {
    "label": "spring-prod",
    "command": "./gradlew bootRun --console=plain --args='--spring.profiles.active=prod'",
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always"
  }
]
