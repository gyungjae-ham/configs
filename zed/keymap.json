// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "escape": "editor::Cancel",
      "tab": "pane::ActivateNextItem",
      "shift-tab": "pane::ActivatePreviousItem",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      "alt-1": "pane::SplitVertical",
      "alt-2": "pane::SplitHorizontal",
    },
  },
  {
    "context": "Editor && vim_mode == normal && !menu",
    "bindings": {
      ", a": "vim::StartOfLine",
      ", f": "vim::EndOfLine",
      ", v": "editor::SelectLargerSyntaxNode",

      // [핵심 수정] 복합 동작은 SendKeystrokes를 사용하여 인자를 하나로 묶어 전달하옵니다.
      ", D": ["workspace::SendKeystrokes", "v i '"],
      ", d": ["workspace::SendKeystrokes", "v i \""],
      ", r": ["workspace::SendKeystrokes", "v i ("],
      ", t": ["workspace::SendKeystrokes", "v i {"],
      ", y": ["workspace::SendKeystrokes", "v $ y"],

      ". a": "editor::SelectAll",

      ", 1": ["pane::ActivateItem", 0],
      ", 2": ["pane::ActivateItem", 1],
      ", 3": ["pane::ActivateItem", 2],
      ", 4": ["pane::ActivateItem", 3],
      ", 5": ["pane::ActivateItem", 4],

      ", e": "editor::GoToDiagnostic",
      ", Q": "pane::CloseAllItems",
      ", g": "pane::CloseActiveItem",
    },
  },
  {
    "context": "Editor && vim_mode == visual && !menu",
    "bindings": {
      ", a": "vim::StartOfLine",
      ", f": "vim::EndOfLine",
      "n": "editor::Outdent",
      ".": "editor::Indent",
    },
  },
  {
    "context": "Workspace || Editor",
    "bindings": {
      "cmd-j": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-/": "editor::ToggleComments"
    }
  },
  {
    "context": "Workspace || Editor",
    "unbind": {
      "alt-f12": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-shift-r": "task::Spawn"
    }
  },
  {
    "bindings": {
      "alt-p": "agent::FocusAgent"
    }
  }
]
